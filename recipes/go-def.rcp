(:name go-def
       :description "Required for go-mode godef functions"
       :type github
       :pkgname "rogpeppe/godef"
       :load-path (()) ; The .el file comes from go-mode.
       :depends (go-mode)
       :build (("go" "build" "-o" "bin/godef" "."))
       :post-init (setq godef-command (concat default-directory "bin/godef")))
